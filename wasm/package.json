{
  "name": "@bulletxyz/sdk-wasm",
  "version": "0.0.5",
  "description": "WebAssembly bindings for the Bullet trading SDK — works in Node.js, browsers, and Deno",
  "author": "Bullet.xyz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bulletxyz/bullet-rust-sdk",
    "directory": "wasm"
  },
  "homepage": "https://bullet.xyz",
  "keywords": [
    "wasm",
    "webassembly",
    "trading",
    "bullet",
    "sdk",
    "typescript",
    "dex"
  ],
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": "cd .. && just build-wasm",
    "prepublishOnly": "[ -n \"$CI\" ] || npm run build"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/pkg/"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ]
  },
  "main": "./pkg/node.js",
  "types": "./pkg/node.d.ts",
  "exports": {
    ".": {
      "node": "./pkg/node.js",
      "default": "./pkg/bullet_rust_sdk_wasm.js"
    }
  },
  "files": [
    "pkg/",
    "README.md"
  ],
  "sideEffects": [
    "./pkg/node.js"
  ]
}
