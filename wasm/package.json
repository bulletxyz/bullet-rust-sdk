{
  "name": "@bulletxyz/sdk-wasm",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/pkg/"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ]
  },
  "main": "./pkg/bullet_rust_sdk_wasm.js",
  "module": "./pkg/bullet_rust_sdk_wasm.js",
  "types": "./pkg/bullet_rust_sdk_wasm.d.ts",
  "exports": {
    ".": {
      "node": "./pkg/node.js",
      "default": "./pkg/bullet_rust_sdk_wasm.js"
    }
  },
  "files": [
    "pkg/"
  ],
  "sideEffects": [
    "./pkg/node.js"
  ]
}
